class Solution:
    def isCyclic(self, V, edges):
        
        adj = [[] for _ in range(V)]
        for u, v in edges:
            adj[u].append(v)
        
        visited = [False] * V
        recStack = [False] * V
        
        def dfs(node):
            visited[node] = True
            recStack[node] = True
            
            for nei in adj[node]:
                if not visited[nei]:
                    if dfs(nei):
                        return True
                elif recStack[nei]:
                    return True
            
            recStack[node] = False
            return False
        
        for i in range(V):
            if not visited[i]:
                if dfs(i):
                    return True
        
        return False
