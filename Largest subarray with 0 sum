class Solution:
    def maxLength(self, arr):
        prefix_sum = 0
        max_length = 0
        mp = {}

        for i in range(len(arr)):
            prefix_sum += arr[i]

            if prefix_sum == 0:
                max_length = i + 1

            if prefix_sum in mp:
                max_length = max(max_length, i - mp[prefix_sum])
            else:
                mp[prefix_sum] = i

        return max_length
